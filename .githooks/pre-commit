#!/bin/sh
set -e
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo "── pre-commit ─────────────────────────────────────────"

echo "→ Verificando entrada no changelog para versão atual..."
node scripts/check-changelog.mjs || exit 1

echo "→ Validando migrations vs schema..."
node scripts/check-migrations.mjs || exit 1

echo "→ Verificando tabelas no banco de produção..."
node scripts/check-prod-db.mjs || exit 1

echo "→ Rodando testes com cobertura..."
npx vitest run --coverage || exit 1

if [ "${RUN_E2E:-}" = "1" ]; then
  echo "→ Rodando suíte E2E completa..."
  npm run e2e:full || exit 1
else
  echo "⚠ E2E pulada localmente — CI cobre. Para rodar: RUN_E2E=1 git commit"
fi

echo "✓ Tudo ok, pode commitar!"
